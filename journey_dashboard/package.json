{
  "name": "journey_dashboard",
  "version": "3.33.19",
  "private": true,
  "type": "module",
  "dependencies": {
    "@types/node": "25.9.5",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "axios": "1.18.1",
    "i18next": "26.3.4",
    "i18next-browser-languagedetector": "8.2.1",
    "i18next-resources-to-backend": "1.2.1",
    "react": "19.2.7",
    "react-bootstrap": "2.10.10",
    "react-dom": "19.2.7",
    "react-i18next": "17.0.8",
    "react-router-dom": "7.18.1",
    "react-select": "5.10.2",
    "uuid": "14.0.1",
    "web-vitals": "5.3.0"
  },
  "scripts": {
    "start": "vite",
    "build": "vite build",
    "watch": "vite build --watch",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run --coverage",
    "test:coverage": "vitest run --coverage",
    "eslint": "eslint ./src",
    "eslint:junit": "eslint ./src --format junit -o /tmp/eslint/js-lint-results-gameday_designer.xml",
    "eslint:json": "eslint ./src --format json -o js-lint-results-gameday_designer.json",
    "dev": "vite build",
    "i18n:types": "i18next-resources-for-ts toc -i ./src/i18n/locales/de -o ./src/i18n/types.d.ts",
    "prebuild": "npm run i18n:types"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "@babel/plugin-transform-private-property-in-object": "8.0.1",
    "@emnapi/core": "^1.11.1",
    "@emnapi/runtime": "^1.11.1",
    "@eslint/js": "10.0.1",
    "@testing-library/dom": "10.4.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/react-router-dom": "5.3.3",
    "@vitejs/plugin-react": "6.0.3",
    "@vitest/coverage-v8": "4.1.10",
    "@vitest/ui": "4.1.10",
    "esbuild": "^0.28.1",
    "eslint": "10.6.0",
    "eslint-formatter-junit": "9.0.1",
    "eslint-plugin-react-hooks": "7.1.1",
    "i18next-resources-for-ts": "2.1.0",
    "jsdom": "29.1.1",
    "typescript": "6.0.3",
    "typescript-eslint": "8.63.0",
    "vite": "8.1.3",
    "vitest": "4.1.10"
  }
}
